# App
ENVIRONMENT=development
PORT=8001

# Internal service auth (must match API service)
INTERNAL_TOKEN=change-me-internal-secret

# ── AI Backend (choose one) ───────────────────────────────────────────────────
# Option A: Gemini API — FREE, no GCP needed, works immediately
# Get key at: aistudio.google.com/app/apikey
GEMINI_BACKEND=gemini_api
GEMINI_API_KEY=your-gemini-api-key

# Option B: Vertex AI MedGemma — switch to this when you have 50+ doctors
# GEMINI_BACKEND=vertex_ai
# GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
# GCP_REGION=asia-south1
# VERTEX_AI_LOCATION=us-central1
# MEDGEMMA_4B_ENDPOINT=medgemma-4b-it
# MEDGEMMA_27B_ENDPOINT=medgemma-27b-it

# CXR Foundation Model
CXR_MODEL_ENDPOINT=your-cxr-endpoint-id

# Drug Interaction Database
DDI_DB_URL=postgresql://cliniqai_user:cliniqai_dev_password@localhost:5432/cliniqai
DDI_API_KEY=your-ddi-api-key

# Rate Limiting
AI_RATE_LIMIT_PER_MINUTE=60

# Sentry
SENTRY_DSN=
