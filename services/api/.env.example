# App
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://cliniqai_user:cliniqai_dev_password@localhost:5432/cliniqai

# Redis
REDIS_URL=redis://localhost:6379

# Auth (JWT)
JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=30d

# Google Cloud
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
GCP_REGION=asia-south1

# Google Cloud Healthcare API (FHIR)
FHIR_DATASET_ID=cliniqai-dataset
FHIR_STORE_ID=cliniqai-fhir
FHIR_BASE_URL=https://healthcare.googleapis.com/v1/projects/${GOOGLE_CLOUD_PROJECT_ID}/locations/${GCP_REGION}/datasets/${FHIR_DATASET_ID}/fhirStores/${FHIR_STORE_ID}/fhir

# ── File Storage (choose one) ─────────────────────────────────────────────────
# Option A: Cloudflare R2 — FREE 10 GB, free egress [DEFAULT for MVP]
# Create bucket at: dash.cloudflare.com → R2
STORAGE_BACKEND=r2
STORAGE_BUCKET=cliniqai-documents
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key

# Option B: Google Cloud Storage — uncomment when on GCP
# STORAGE_BACKEND=gcs
# STORAGE_BUCKET=cliniqai-documents-prod
# GCS_HMAC_KEY=your-gcs-hmac-key
# GCS_HMAC_SECRET=your-gcs-hmac-secret

# Internal service auth
AI_SERVICE_URL=http://localhost:8001
AI_INTERNAL_TOKEN=change-me-internal-secret
INTERNAL_API_TOKEN=change-me-internal-secret
FHIR_SERVICE_URL=http://localhost:3002
NOTIFICATIONS_SERVICE_URL=http://localhost:3003

# SMS / WhatsApp (MSG91)
MSG91_API_KEY=your-msg91-api-key
MSG91_SENDER_ID=CLNQAI
MSG91_TEMPLATE_OTP=your-otp-template-id
MSG91_TEMPLATE_APPOINTMENT=your-appointment-template-id
WHATSAPP_AUTH_KEY=your-whatsapp-auth-key

# Push notifications
PUSH_NOTIFICATION_KEY=your-fcm-server-key

# Encryption (AES-256-GCM for PHI fields)
ENCRYPTION_KEY=your-32-char-encryption-key-here

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19000

# Sentry
SENTRY_DSN=

# Demo mode — OTP returned in API response for easy login (dev only)
ALLOW_DEV_OTP=true
