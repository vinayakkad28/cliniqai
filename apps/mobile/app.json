{
  "expo": {
    "name": "CliniqAI",
    "slug": "cliniqai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#178590"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cliniqai.doctor"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#178590"
      },
      "package": "com.cliniqai.doctor"
    },
    "plugins": ["expo-router"],
    "scheme": "cliniqai"
  }
}
