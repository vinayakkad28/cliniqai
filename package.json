{
  "name": "cliniqai",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @cliniqai/api dev",
    "dev:fhir": "pnpm --filter @cliniqai/fhir dev",
    "dev:notifications": "pnpm --filter @cliniqai/notifications dev",
    "dev:web": "pnpm --filter @cliniqai/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @cliniqai/api db:migrate",
    "db:generate": "pnpm --filter @cliniqai/api db:generate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
