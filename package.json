{
  "name": "cliniqai",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web,ai -c blue,green,yellow \"pnpm dev:api\" \"pnpm dev:web\" \"pnpm dev:ai\"",
    "dev:api": "pnpm --filter @cliniqai/api dev",
    "dev:fhir": "pnpm --filter @cliniqai/fhir dev",
    "dev:notifications": "pnpm --filter @cliniqai/notifications dev",
    "dev:web": "pnpm --filter @cliniqai/web dev",
    "dev:ai": "cd services/ai && poetry run uvicorn app.main:app --reload --port 8001",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @cliniqai/api db:migrate",
    "db:generate": "pnpm --filter @cliniqai/api db:generate",
    "db:studio": "pnpm --filter @cliniqai/api db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
